<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gaming Zone</title>  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    header {
      background: #020617;
      padding: 15px;
      text-align: center;
      font-size: 24px;
      font-weight: bold;
      letter-spacing: 2px;
    }

    nav {
      display: flex;
      justify-content: center;
      background: #1e293b;
      padding: 10px;
    }

    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      color: cyan;
    }

    .container {
      padding: 20px;
      text-align: center;
    }

    .game-card {
      background: #1e293b;
      padding: 20px;
      margin: 15px;
      border-radius: 10px;
      display: inline-block;
      width: 250px;
    }

    button {
      margin-top: 10px;
      padding: 10px;
      background: #22c55e;
      border: none;
      color: white;
      border-radius: 5px;
      cursor: pointer;
    }

    button:hover {
      background: #16a34a;
    }

    #gameArea {
      margin-top: 30px;
    }

    footer {
      background: #020617;
      text-align: center;
      padding: 10px;
      position: fixed;
      bottom: 0;
      width: 100%;
    }
  </style></head><body><header>
  🎮 GAMING ZONE
</header><nav>
  <a href="#">Home</a>
  <a href="#">Games</a>
  <a href="#">Contact</a>
</nav><div class="container">
  <h2>Select a Game</h2>  <div class="game-card">
    <h3>Number Guessing</h3>
    <p>Guess the number between 1 - 10</p>
    <button onclick="startGame()">Play</button>
  </div>  <div id="gameArea"></div>
</div><footer>
  <p>© 2026 Gaming Zone</p>
</footer><script>
  let randomNumber;

  function startGame() {
    randomNumber = Math.floor(Math.random() * 10) + 1;

    document.getElementById("gameArea").innerHTML = `
      <h3>Guess the Number (1-10)</h3>
      <input type="number" id="guess" />
      <button onclick="checkGuess()">Submit</button>
      <p id="result"></p>
    `;
  }

  function checkGuess() {
    let userGuess = document.getElementById("guess").value;

    if (userGuess == randomNumber) {
      document.getElementById("result").innerHTML = "🎉 Correct! You Win!";
    } else {
      document.getElementById("result").innerHTML = "❌ Wrong! Try Again";
    }
  }
</script></body>
</html>
